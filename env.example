# PostgreSQL connection URL supplied by Railway or another host
DATABASE_URL="postgresql://user:password@host:5432/charlotte_land_scanner"

# Shared team login for the private dashboard
TEAM_USERNAME="land-team"
TEAM_PASSWORD="replace-with-a-long-random-password"

# Gmail OAuth - create these in Google Cloud Console
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI="https://your-railway-domain.up.railway.app/api/auth/gmail/callback"
GMAIL_REFRESH_TOKEN=""

# Alert email sender/recipient
ALERT_TO_EMAIL="your-email@gmail.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# Optional: use a real browser user agent for Nominatim
NOMINATIM_EMAIL="your-email@gmail.com"

# Optional: enables the "Research utilities" button on saved/listed parcels
OPENAI_API_KEY=""
OPENAI_UTILITY_MODEL="gpt-4.1-mini"
